#!/bin/bash

# Configuration
API_KEY=""  # Replace with your actual API key
CITY="Jeddah"              # Replace with your city
UNITS="metric"               # metric for Celsius, imperial for Fahrenheit
LANG="en"                    # Language for weather description

# API URL
URL="https://api.openweathermap.org/data/2.5/weather?q=${CITY}&units=${UNITS}&lang=${LANG}&appid=${API_KEY}"

# Get weather data
weather_data=$(curl -s "$URL")

# # Check if API call was successful
if [[ -z "$weather_data" ]]; then
    echo "ÔĀĪ Weather NA"
    exit 1
fi

# Parse JSON data (using jq - install with your package manager if needed)
temp=$(echo "$weather_data" | jq '.main.temp')
condition=$(echo "$weather_data" | jq -r '.weather[0].description')
icon_code=$(echo "$weather_data" | jq -r '.weather[0].icon')
humidity=$(echo "$weather_data" | jq '.main.humidity')
wind_speed=$(echo "$weather_data" | jq '.wind.speed')

# Map icon codes to Nerd Font icons
case $icon_code in
    "01d") icon="ÔÜÖ";;  # clear sky day
    "01n") icon="ÔÜÜ";;  # clear sky night
    "02d") icon="ÓĽį";;  # few clouds day
    "02n") icon="ÓĽĮ";;  # few clouds night
    "03d"|"03n") icon="ÔÉā";;  # scattered clouds
    "04d"|"04n") icon="ÔÉā";;  # broken clouds
    "09d"|"09n") icon="Óľú";;  # shower rain
    "10d"|"10n") icon="Óľú";;  # rain
    "11d"|"11n") icon="ÔÉß";;  # thunderstorm
    "13d"|"13n") icon="Ôčú";;  # snow
    "50d"|"50n") icon="Óćļ";;  # mist
    *) icon="ÔĀĪ";;        # unknown
esac

# Format output
# echo "$icon ${temp%.*}¬įC Óľę ${humidity}% ÓľĖ ${wind_speed}m/s"
echo "$icon ${temp%.*}¬įC ${condition^}"
# Alternative without humidity and wind: echo "$icon ${temp%.*}¬įC ${condition^}"
