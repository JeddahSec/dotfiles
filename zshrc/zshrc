# --- 1. NON-INTERACTIVE GUARD (Saves resources for scripts) ---
[[ $- != *i* ]] && return

# --- 2. PATH CONFIGURATION ---
# Zsh-native way to handle PATH: 'path' array automatically syncs with '$PATH'
typeset -U path # Ensure only unique paths are kept

# Define all paths to prepend (if they exist)
local_paths=(
    "$HOME/.bin"
    "$HOME/.local/bin"
    "$HOME/.local/bin/statusbar"
    "$HOME/Applications"
    "/var/lib/flatpak/exports/bin"
    "/usr/lib/packettracer"
)

for dir in $local_paths; do
    [[ -d "$dir" ]] && path=("$dir" $path)
done

# Append snap binaries safely
[[ -d "/snap/bin" ]] && path+=("/snap/bin")

# --- 3. OH MY ZSH SETUP ---
export ZSH="$HOME/.oh-my-zsh"

# Set to "" to let Starship control the prompt, or "robbyrussell" to use default
ZSH_THEME="robbyrussell" 
plugins=(git)

source "$ZSH/oh-my-zsh.sh"

# --- 4. ENVIRONMENT VARIABLES ---
export BROWSER='qutebrowser'
export MANPAGER="nvim +Man!"                              # Use Neovim as manpager
export TEXMFCNF='~/.local/bin/tex_config_dir:'
export XCURSOR_SIZE=16
export QT_STYLE_OVERRIDE=Adwaita-Dark                     # Wireshark dark mode
export _JAVA_AWT_WM_NONREPARENTING=1                     # Fix Java WM Problem

# History Configuration
export HISTORY_IGNORE="(ls|cd|pwd|exit|sudo reboot|history|cd -|cd ..)"
HISTFILE="$HOME/.zsh_history"                             # Restored so you don't lose history completely
HISTSIZE=50                                               # Small size as per your original preference
SAVEHIST=50

# Cursor style fix
_fix_cursor() {
   echo -ne '\e[5 q'
}
precmd_functions+=(_fix_cursor)

# Vi keybindings
bindkey -e

# --- 5. ALIASES & FUNCTIONS ---

# Core Replacements (Check if binary exists before aliasing)
alias vim="nvim"
if command -v eza &> /dev/null; then
    alias ls='eza -al --color=always --group-directories-first'
    alias la='eza -a --color=always --group-directories-first'
    alias ll='eza -l --color=always --group-directories-first'
    alias lt='eza -aT --color=always --group-directories-first'
    alias l.='eza -al --color=always --group-directories-first ../'
    alias l..='eza -al --color=always --group-directories-first ../../'
    alias l...='eza -al --color=always --group-directories-first ../../../'
fi

if command -v bat &> /dev/null; then
    alias cat='bat --theme=base16'
    alias catn='bat --style=plain --theme=base16'
    alias catnp='bat --style=plain --paging=never --theme=base16'
fi

# Pacman & Yay/Paru
alias pacsyu='sudo pacman -Syu'
alias pacsyyu='sudo pacman -Syyu'
alias parsua='paru -Sua --noconfirm'
alias parsyu='paru -Syu --noconfirm'
alias unlock='sudo rm -f /var/lib/pacman/db.lck'
alias orphan='sudo pacman -Rns $(pacman -Qtdq)'

# System Tools
alias df='df -h'
alias free='free -m'
alias grep='grep --color=auto'
alias ip='ip -c'

# Process Management
alias psa="ps auxf"
alias psgrep="ps aux | grep -v grep | grep -i -e VSZ -e"
alias psmem='ps auxf | sort -nr -k 4'
alias pscpu='ps auxf | sort -nr -k 3'

# Xresources & Live Server
alias merge='xrdb -merge ~/.Xresources'
alias liveserver='browser-sync start --server --files "*.html, *.css, *.js"'

# Git
alias addup='git add -u'
alias addall='git add .'
alias branch='git branch'
alias checkout='git checkout'
alias clone='git clone'
alias commit='git commit -m'
alias fetch='git fetch'
alias pull='git pull origin'
alias push='git push origin'
alias stat='git status'
alias tag='git tag'
alias newtag='git tag -a'

# Directory preparation helper
mkt() {
    mkdir -p nmap content exploits
}

# --- 6. PLUGINS & EXTERNAL INTEGRATIONS ---

# Shell Color Scripts (Checks if installed to prevent startup errors)
if command -v colorscript &> /dev/null; then
    colorscript random
fi

# FZF Configuration
if command -v fzf &> /dev/null; then
    source <(fzf --zsh)
    export FZF_DEFAULT_COMMAND='ag -u -g ""'
    export FZF_DEFAULT_OPTS='
    --layout=reverse
    --exact
    --border=rounded
    --padding=0,1
    --margin=4,10
    --color=dark
    --color=fg:-1,bg:-1,hl:#c678dd,fg+:#ffffff,bg+:#4b5263,hl+:#d858fe
    --color=info:#98c379,prompt:#61afef,pointer:#be5046,marker:#e5c07b,spinner:#61afef,header:#61afef,gutter:-1,border:#1f2335
    '
fi

# Starship Prompt (Uncomment if you want to use it instead of robbyrussell)
# if command -v starship &> /dev/null; then
#     eval "$(starship init zsh)"
# fi

# Syntax Highlighting (Always must be last)
# Wraps in conditional to prevent shell crash if not installed on a specific machine
SF_PATH="/usr/share/zsh/plugins/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh"
[[ -f "$SF_PATH" ]] && source "$SF_PATH"
